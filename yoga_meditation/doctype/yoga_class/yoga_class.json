{
 "autoname": "YM-CLS-.YYYY.-.####",
 "doctype": "DocType",
 "engine": "InnoDB",
 "is_submittable": 1,
 "field_order": [
  "class_name","class_type","status","section_schedule",
  "instructor","room_location","class_date","start_time","end_time","duration_minutes",
  "column_break_sched","max_capacity","enrolled_count","available_slots",
  "is_recurring","recurrence_pattern","recurrence_end_date",
  "section_content","description","class_image","difficulty_level","tags",
  "section_pricing","fee_per_class","is_free_for_members","included_in_packages",
  "section_enrollment","enrolled_students"
 ],
 "fields": [
  {"fieldname":"class_name","fieldtype":"Data","label":"Class Name","reqd":1,"in_list_view":1},
  {"fieldname":"class_type","fieldtype":"Select","label":"Class Type","options":"Yoga\nMeditation\nYoga + Meditation\nWorkshop\nRetreat","reqd":1,"in_list_view":1,"in_standard_filter":1},
  {"fieldname":"status","fieldtype":"Select","label":"Status","options":"Draft\nScheduled\nIn Progress\nCompleted\nCancelled","default":"Draft","in_list_view":1,"in_standard_filter":1},
  {"fieldname":"section_schedule","fieldtype":"Section Break","label":"Schedule"},
  {"fieldname":"instructor","fieldtype":"Link","label":"Instructor","options":"Instructor","reqd":1,"in_list_view":1,"in_standard_filter":1},
  {"fieldname":"room_location","fieldtype":"Data","label":"Room / Location"},
  {"fieldname":"class_date","fieldtype":"Date","label":"Class Date","reqd":1,"in_standard_filter":1},
  {"fieldname":"start_time","fieldtype":"Time","label":"Start Time","reqd":1},
  {"fieldname":"end_time","fieldtype":"Time","label":"End Time"},
  {"fieldname":"duration_minutes","fieldtype":"Int","label":"Duration (Minutes)","default":60},
  {"fieldname":"column_break_sched","fieldtype":"Column Break"},
  {"fieldname":"max_capacity","fieldtype":"Int","label":"Max Capacity","default":20},
  {"fieldname":"enrolled_count","fieldtype":"Int","label":"Enrolled","default":0,"read_only":1},
  {"fieldname":"available_slots","fieldtype":"Int","label":"Available Slots","read_only":1},
  {"fieldname":"is_recurring","fieldtype":"Check","label":"Is Recurring","default":0},
  {"fieldname":"recurrence_pattern","fieldtype":"Select","label":"Recurrence Pattern","options":"\nDaily\nWeekly\nBi-Weekly\nMonthly","depends_on":"is_recurring"},
  {"fieldname":"recurrence_end_date","fieldtype":"Date","label":"Recurrence End Date","depends_on":"is_recurring"},
  {"fieldname":"section_content","fieldtype":"Section Break","label":"Class Details"},
  {"fieldname":"description","fieldtype":"Text Editor","label":"Description"},
  {"fieldname":"class_image","fieldtype":"Attach Image","label":"Class Image"},
  {"fieldname":"difficulty_level","fieldtype":"Select","label":"Difficulty","options":"All Levels\nBeginner\nIntermediate\nAdvanced"},
  {"fieldname":"tags","fieldtype":"Data","label":"Tags"},
  {"fieldname":"section_pricing","fieldtype":"Section Break","label":"Pricing"},
  {"fieldname":"fee_per_class","fieldtype":"Currency","label":"Fee per Class"},
  {"fieldname":"is_free_for_members","fieldtype":"Check","label":"Free for Active Members","default":1},
  {"fieldname":"included_in_packages","fieldtype":"Check","label":"Included in Packages","default":1},
  {"fieldname":"section_enrollment","fieldtype":"Section Break","label":"Enrolled Students"},
  {"fieldname":"enrolled_students","fieldtype":"Table","label":"Enrolled Students","options":"Class Enrollment"}
 ],
 "module": "Yoga Meditation",
 "name": "Yoga Class",
 "naming_rule": "Expression",
 "permissions": [
  {"create":1,"delete":1,"email":1,"print":1,"read":1,"report":1,"role":"System Manager","share":1,"submit":1,"cancel":1,"amend":1,"write":1},
  {"create":1,"email":1,"print":1,"read":1,"report":1,"role":"Yoga Manager","share":1,"submit":1,"write":1},
  {"read":1,"print":1,"role":"Yoga Instructor"}
 ],
 "title_field": "class_name",
 "track_changes": 1
}
