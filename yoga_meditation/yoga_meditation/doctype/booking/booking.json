  "section_class","yoga_class","meditation_session","column_break_1",
  "wellness_package","package_start_date","package_end_date",
  "section_payment","amount","discount","net_amount","payment_status","payment_method","sales_invoice",
  "section_notes","special_requests","notes"
 ],
