  {"fieldname":"booking_status","fieldtype":"Select","label":"Status","options":"Pending\nConfirmed\nCompleted\nCancelled\nNo Show","default":"Pending","in_list_view":1,"in_standard_filter":1},
  {"fieldname":"booking_date","fieldtype":"Date","label":"Booking Date","default":"Today","reqd":1,"in_standard_filter":1},
  {"fieldname":"section_class","fieldtype":"Section Break","label":"Booking Reference"},
  {"fieldname":"yoga_class","fieldtype":"Link","label":"Yoga Class","options":"Yoga Class","depends_on":"eval:doc.booking_type=='Single Class'"},
  {"fieldname":"meditation_session","fieldtype":"Link","label":"Meditation Session","options":"Meditation Session","depends_on":"eval:doc.booking_type=='Meditation Session'"},
  {"fieldname":"column_break_1","fieldtype":"Column Break"},
  {"fieldname":"wellness_package","fieldtype":"Link","label":"Wellness Package","options":"Wellness Package","depends_on":"eval:doc.booking_type=='Wellness Package'"},
  {"fieldname":"package_start_date","fieldtype":"Date","label":"Package Start Date","depends_on":"eval:doc.booking_type=='Wellness Package'"},
  {"fieldname":"package_end_date","fieldtype":"Date","label":"Package End Date","depends_on":"eval:doc.booking_type=='Wellness Package'","read_only":1},
  {"fieldname":"section_payment","fieldtype":"Section Break","label":"Payment"},
  {"fieldname":"amount","fieldtype":"Currency","label":"Amount"},
  {"fieldname":"discount","fieldtype":"Currency","label":"Discount"},
